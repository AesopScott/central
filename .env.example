# MindShare Central — environment template (keys only, no secrets).
# Copy to .env.local and fill in real values. .env.local is gitignored.

# DeepSeek (Combo review + DeepSeek provider)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
DEEPSEEK_API_BASE_URL=

# Kling video
KLING_ACCESS_KEY_ID=
KLING_ACCESS_KEY_SECRET=
KLING_API_DOMAIN=
KLING_API_KEY=

# Meetup visualization
MEETUP_CLIENT_ID=
MEETUP_CLIENT_SECRET=
MEETUP_REDIRECT_URI=
MEETUP_ADMIN_KEY=

# Cloudflare analytics
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Zoom
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_SECRET_TOKEN=

# MindShare Central video branding (optional overrides; sensible defaults in code)
MINDSHARE_VIDEO_BRAND_NAME=
MINDSHARE_VIDEO_LOGO_DIRECTION=
