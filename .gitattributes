# Normalize line endings. Repo stores LF; checkout native per-OS.
* text=auto

# Force LF for shell/web/config (avoid CRLF leaking into repo)
*.sh    text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.ts    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Windows-native scripts keep CRLF
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binaries — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.zip   binary
*.exe   binary
*.dll   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
